# SampleBakefile: a sample Bakefile. Run this with
# >> bake -f SampleBakefile

# lead target is 'demo' which will be used if
# no target is specified on the command line.
# Some of the commands have @ as their prefix which
# silences the command.
demo : hello bye
	@ echo Running programs
	./hello
	./bye
	@ echo Done running programs

all : hello bye

# this is program 1 / 2
hello : hello.o
	gcc -o hello hello.o

hello.o : hello.c
	gcc -c hello.c

# this is program 2 / 2
bye : bye.o
	gcc -o bye bye.o

bye.o : bye.c
	gcc -c bye.c

# this target removes built files
clean :
	rm -f hello.o bye.o hello bye

# END of SampleBakefile
